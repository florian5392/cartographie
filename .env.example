# Mot de passe PostgreSQL (changez en production)
POSTGRES_PASSWORD=changeme_in_production

# --- Cloudflare Tunnel (optionnel) ---
# Nom du réseau Docker exposé par votre stack cloudflared.
# Doit correspondre au `name:` déclaré dans l'autre docker-compose.
# Laisser vide ou supprimer si vous n'utilisez pas Cloudflare Tunnel.
CLOUDFLARE_NETWORK_NAME=cloudflare_tunnel
